# =============================================================================
# FitStake Environment Variables
# Copy this to .env and fill in your values
# =============================================================================

# --- Strava OAuth ---
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:3000/api/strava/callback

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Privy ---
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# --- Blockchain ---
BASE_SEPOLIA_RPC=https://sepolia.base.org
PRIVATE_KEY=
ETHERSCAN_API_KEY=

# --- Chainlink ---
CHAINLINK_VRF_SUBSCRIPTION_ID=
CHAINLINK_VRF_KEY_HASH=0x787d74caea10b2b357790d5b5247c2f63d1d91572a9846f780606e4d953677ae

# --- Contract Addresses (filled after deployment) ---
NEXT_PUBLIC_FITSTAKE_ADDRESS=
NEXT_PUBLIC_FITSTAKE_VRF_ADDRESS=

# --- Chain Config ---
NEXT_PUBLIC_CHAIN_ID=84532

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
